<Window x:Class="PomodoroDataManager.EditRecordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="レコードの編集" Height="440" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1A1A2E">
    <Window.Resources>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- タイトル -->
            <RowDefinition Height="*"/>    <!-- 入力項目 -->
            <RowDefinition Height="Auto"/> <!-- ボタン -->
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="EDIT HISTORY RECORD" FontSize="16" FontWeight="Bold" Foreground="#E2E8F0"/>
            <Rectangle Height="2" Fill="#E94560" HorizontalAlignment="Left" Width="60" Margin="0,5,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <!-- 作業内容 -->
            <TextBlock Text="TASK DESCRIPTION" Margin="0,0,0,5" Foreground="#7A8BA8" FontSize="10" FontWeight="Bold"/>
            <TextBox x:Name="TaskNameTextBox" Margin="0,0,0,15" TextChanged="TaskName_TextChanged"/>

            <!-- モード -->
            <TextBlock Text="MODE" Margin="0,0,0,5" Foreground="#7A8BA8" FontSize="10" FontWeight="Bold"/>
            <ComboBox x:Name="ModeComboBox" Margin="0,0,0,15" SelectionChanged="Mode_SelectionChanged">
                <ComboBoxItem Content="作業"/>
                <ComboBoxItem Content="休憩"/>
            </ComboBox>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="START TIME" Margin="0,0,0,5" Foreground="#7A8BA8" FontSize="10" FontWeight="Bold"/>
                    <DatePicker x:Name="StartDatePicker" BorderThickness="0" SelectedDateChanged="TimeChanged"/>
                    <TextBox x:Name="StartTimeText" Margin="0,5,0,0" FontFamily="Consolas" Height="28" TextChanged="TimeChanged"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="▶" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,15,0,0" Foreground="#3F3F6F"/>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="END TIME" Margin="0,0,0,5" Foreground="#7A8BA8" FontSize="10" FontWeight="Bold"/>
                    <DatePicker x:Name="EndDatePicker" BorderThickness="0" SelectedDateChanged="TimeChanged"/>
                    <TextBox x:Name="EndTimeText" Margin="0,5,0,0" FontFamily="Consolas" Height="28" TextChanged="TimeChanged"/>
                </StackPanel>
            </Grid>

            <!-- 経過時間 -->
            <Border Background="#0F3460" Padding="15,8" CornerRadius="4" HorizontalAlignment="Right" BorderBrush="#1F2937" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="DURATION: " VerticalAlignment="Center" Foreground="#A0AEC0" FontSize="11" Margin="0,0,5,0"/>
                    <TextBlock x:Name="DurationTextBlock" Text="00:00" FontSize="20" FontWeight="Bold" Foreground="#E94560" FontFamily="Consolas"/>
                </StackPanel>
            </Border>

            <!-- バリデーションメッセージ -->
            <TextBlock x:Name="ValidationMessage" Text="" FontSize="11" Foreground="#E94560" 
                       HorizontalAlignment="Right" Margin="0,6,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,15,0,0">
            <!-- 削除ボタン（新規作成時は非表示） -->
            <Button x:Name="DeleteButton" Content="DELETE" Width="90" Height="32" Click="DeleteButton_Click" Style="{StaticResource InstrumentButton}" Foreground="#E94560" BorderBrush="#E94560"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Width="290">
                <Button Content="CANCEL" Width="90" Height="32" Margin="0,0,10,0" IsCancel="True" Style="{StaticResource InstrumentButton}"/>
                <Button Content="SAVE CHANGES" Width="120" Height="32" x:Name="SaveButton" Click="SaveButton_Click" Style="{StaticResource AccentButton}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
